# Fundus Images Directory
# Path to the folder that contains retina/fundus images.
# Use an absolute or relative directory path and keep a trailing slash.
# Example: ./path-to-fundus-images/
FUNDUS_IMAGES_PATH=your-fundus-images-directory-path

# Vessel Structure Images Directory
# Path to the folder that contains vessel structure images.
# Use an absolute or relative directory path and keep a trailing slash.
# Example: ./path-to-vessel-images/
VESSEL_STRUCTURE_PATH=your-vessel-images-directory-path

# Optic Disc Centers CSV Path
# Path to the CSV file used for optic disc center data/results.
# Example: ./optic_disc_centres.csv
RESULT_CSV_PATH=your-optic-disc-centers-csv-path

# Output Images Directory
# Path to the folder where processed images will be saved.
# Use an absolute or relative directory path and keep a trailing slash.
# Example: ./output/
RESULT_PATH=your-output-directory-path
